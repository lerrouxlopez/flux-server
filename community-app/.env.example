APP_ENV=local
HTTP_ADDR=0.0.0.0:8080
WS_ADDR=0.0.0.0:8081

DATABASE_URL=postgres://app:app@localhost:5432/community_app
REDIS_URL=redis://localhost:6379
NATS_URL=nats://localhost:4222

JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000

LIVEKIT_URL=http://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# Docker Compose note:
# - Containers should talk to LiveKit via `LIVEKIT_URL_INTERNAL` (service DNS, e.g. http://livekit:7880).
# - Browsers should talk to LiveKit via `LIVEKIT_URL_PUBLIC` (host port, e.g. http://localhost:7880).
# If these are not set, the app falls back to `LIVEKIT_URL` for both.
#
# LIVEKIT_URL_INTERNAL=http://livekit:7880
# LIVEKIT_URL_PUBLIC=http://localhost:7880
