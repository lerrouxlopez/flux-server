APP_ENV=prod

# Flux backend will be reverse-proxied by nginx to these internal ports.
HTTP_ADDR=0.0.0.0:8080
WS_ADDR=0.0.0.0:8081

JWT_ACCESS_SECRET=change-me
JWT_REFRESH_SECRET=change-me
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000

# Public URL used by the API when minting LiveKit join tokens.
# This must be reachable by browsers (wss/https). Nginx proxies /rtc and /signal to LiveKit.
LIVEKIT_URL_PUBLIC=https://fluxserver.kineticapp.online

# If you want the web UI (flux.kineticapp.online) to call the API (fluxserver.kineticapp.online) directly,
# set CORS allowlist to include the web origin.
CORS_ALLOW_ORIGINS=https://flux.kineticapp.online

LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
